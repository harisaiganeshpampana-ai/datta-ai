{
  "appId": "com.datta.ai",
  "appName": "Datta AI",
  "webDir": ".",
  "server": {
    "url": "https://datta-ai.com",
    "cleartext": false
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#0a0a0a",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    }
  }
}
